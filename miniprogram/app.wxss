page {
  min-height: 100%;
  background: #09090b;
  color: #fafafa;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1.4;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx;
  background:
    radial-gradient(circle at 50% 0%, rgba(226, 182, 79, 0.16), transparent 36%),
    #09090b;
}

.section {
  margin-top: 28rpx;
}

.card {
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 28rpx;
  background: rgba(15, 15, 19, 0.88);
  box-shadow: 0 20rpx 70rpx rgba(0, 0, 0, 0.28);
}

.card-pad {
  padding: 28rpx;
}

.eyebrow {
  color: #e2b64f;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.title-xl {
  color: #ffffff;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.12;
}

.title-lg {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 850;
  line-height: 1.25;
}

.title-md {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.body {
  color: #a1a1aa;
  font-size: 26rpx;
  line-height: 1.7;
}

.muted {
  color: #71717a;
  font-size: 23rpx;
  line-height: 1.55;
}

.row {
  display: flex;
  align-items: center;
}

.space-between {
  justify-content: space-between;
}

.wrap {
  flex-wrap: wrap;
}

.gap-sm {
  gap: 12rpx;
}

.gap-md {
  gap: 18rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  background: rgba(226, 182, 79, 0.12);
  color: #f5d98a;
  font-size: 22rpx;
  font-weight: 700;
}

.tag {
  display: inline-flex;
  align-items: center;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 14rpx;
  padding: 7rpx 14rpx;
  color: #d4d4d8;
  font-size: 21rpx;
  font-weight: 650;
}

.btn-primary,
.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80rpx;
  border-radius: 18rpx;
  padding: 0 26rpx;
  font-size: 26rpx;
  font-weight: 850;
}

.btn-primary {
  background: #e2b64f;
  color: #09090b;
}

.btn-secondary {
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.04);
  color: #ffffff;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.metric {
  border-radius: 22rpx;
  padding: 22rpx;
  background: rgba(255, 255, 255, 0.04);
}

.metric-value {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
}

.metric-label {
  margin-top: 6rpx;
  color: #71717a;
  font-size: 22rpx;
}

.divider {
  height: 1rpx;
  margin: 24rpx 0;
  background: rgba(255, 255, 255, 0.1);
}
