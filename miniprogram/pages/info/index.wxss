.mt {
  margin-top: 24rpx;
}

.mt-sm {
  margin-top: 14rpx;
}

.gold {
  border-color: rgba(226, 182, 79, 0.34);
  color: #f5d98a;
}

.category-scroll {
  margin: 24rpx -28rpx 0;
  white-space: nowrap;
}

.category-row {
  display: flex;
  gap: 12rpx;
  padding: 0 28rpx;
}

.category {
  flex-shrink: 0;
  min-height: 64rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 999rpx;
  padding: 0 26rpx;
  color: #a1a1aa;
  font-size: 24rpx;
  font-weight: 750;
}

.category.on {
  border-color: #e2b64f;
  background: rgba(226, 182, 79, 0.14);
  color: #f5d98a;
}

.info-card {
  margin-top: 18rpx;
}

.read-link {
  margin-top: 20rpx;
  color: #e2b64f;
  font-size: 25rpx;
  font-weight: 850;
}
