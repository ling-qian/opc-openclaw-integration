.mt {
  margin-top: 18rpx;
}

.mt-sm {
  margin-top: 14rpx;
}

.search-wrap {
  margin-top: 28rpx;
}

.search {
  width: 100%;
  height: 82rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 18rpx;
  padding: 0 24rpx;
  background: rgba(255, 255, 255, 0.04);
  color: #ffffff;
  font-size: 26rpx;
}

.segmented {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 18rpx;
  padding: 8rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.05);
}

.seg {
  min-height: 68rpx;
  border-radius: 16rpx;
  color: #a1a1aa;
  font-size: 25rpx;
  font-weight: 800;
}

.seg.on {
  background: #e2b64f;
  color: #09090b;
}

.asset-card {
  margin-top: 18rpx;
}

.asset-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 24rpx;
}

.price {
  flex-shrink: 0;
  color: #f5d98a;
  font-size: 28rpx;
  font-weight: 900;
}

.gold {
  border-color: rgba(226, 182, 79, 0.34);
  color: #f5d98a;
}

.min {
  min-width: 0;
}
